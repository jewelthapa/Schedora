# Schedora — environment variable template
# Copy this to `.env` and fill in real values. Do NOT commit `.env`.

# --- Flask ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-64-character-hex-string

# --- MySQL ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=schedora